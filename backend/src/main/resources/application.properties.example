# ============================================================
#  ResumeAI Pro — application.properties.example
#  Copy this file to application.properties and fill in values
# ============================================================

# Server Configuration
server.port=8080
server.servlet.context-path=/api

# Database Configuration
spring.datasource.url=jdbc:mysql://localhost:3306/resume_analyzer?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=root
spring.datasource.password=Au@123456
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA / Hibernate
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.open-in-view=false

# JWT Configuration
# Generate secret with: openssl rand -hex 32
app.jwt.secret=YOUR_256_BIT_HEX_JWT_SECRET
app.jwt.expiration-ms=86400000

# Groq AI Configuration
# Get your free API key at: https://console.groq.com/keys
app.groq.api-key=YOUR_GROQ_API_KEY

# File Upload Configuration
spring.servlet.multipart.enabled=true
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB

# Logging
logging.level.com.resumeanalyzer=DEBUG
logging.level.org.springframework.security=WARN

# CORS
app.cors.allowed-origins=http://localhost:5173,http://localhost:3000
