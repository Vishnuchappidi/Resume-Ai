# ============================================================
#  ResumeAI Pro — .gitignore
#  Protects secrets and excludes build artifacts
# ============================================================

# ── Environment files (NEVER commit these) ──────────────────
.env
.env.local
.env.production
backend/.env
frontend/.env

# ── application.properties (contains real secrets) ──────────

# ── Java / Maven ────────────────────────────────────────────
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
*.class
*.jar
*.war
*.ear
*.nar

# ── IDE ─────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Node / Frontend ─────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS files ────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Logs ────────────────────────────────────────────────────
*.log
logs/

# ── Misc ────────────────────────────────────────────────────
*.tmp
*.temp
*.swp
